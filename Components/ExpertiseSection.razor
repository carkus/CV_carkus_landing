            ["Flutter", "SwiftUI", "UIKit", "Kotlin", "Jetpack Compose"]),

        new("02",
            "https://images.unsplash.com/photo-1617802690992-15d93263d3a9?w=380&q=70",
            "Spatial",
            "Spatial Computing",
            "Early visionOS developer. RealityKit, ARKit, hand-tracking gesture systems, custom animation via FromToByAnimation, and spatial UI architecture.",
            ["visionOS", "RealityKit", "ARKit", "SwiftUI"]),

        new("03",
            "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=380&q=70",
            "Web",
            "Web & Backend",
            "Blazor WebAssembly as a primary differentiator, alongside ASP.NET Core APIs, deployment on DigitalOcean, and familiarity with React and Vue.",
            ["Blazor WASM", "C#", "ASP.NET Core", "React"]),

        new("04",
            "https://images.unsplash.com/photo-1676299081847-824916de030a?w=380&q=70",
