@inject IJSRuntime JS

<section id="expertise">
    <div class="section-inner">
        <div class="section-eyebrow reveal">Expertise</div>
        <h2 class="section-heading reveal reveal-delay-1">Areas of depth</h2>
    </div>
    <div style="max-width:1280px;margin:0 auto;padding-left:3rem;padding-right:3rem;">
        <div class="scroll-hint reveal" style="padding:1.4rem 0 1.4rem;max-width:none;margin:0;">
            Drag to explore <span>→</span>
        </div>
    </div>
    <div style="max-width:1280px;margin:0 auto;overflow:hidden;">
        <div class="expertise-scroll-area" id="expertiseScroll">
            @foreach (var p in Panels)
            {
                <div class="expertise-panel" data-num="@p.Num">
                    <img src="@p.Img" alt="@p.Alt"
                         style="width:100%;height:140px;object-fit:cover;margin-bottom:1.5rem;filter:brightness(0.6);" />
                    <div class="expertise-panel-title">@p.Title</div>
                    <p class="expertise-panel-desc">@p.Desc</p>
                    <div class="expertise-tags">
                        @foreach (var tag in p.Tags)
                        {
                            <span class="etag">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("initDragScroll", "expertiseScroll");
    }

    private record Panel(string Num, string Img, string Alt, string Title, string Desc, string[] Tags);

    private static readonly Panel[] Panels =
    [
        new("01",
            "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?w=380&q=70",
