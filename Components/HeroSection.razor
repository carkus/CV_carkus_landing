@implements IDisposable
@inject IConfiguration Config
@inject HttpClient Http
@using System.Text.Json

<section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid-lines"></div>
    <div class="hero-inner">
        <div class="hero-content">
            <div class="hero-eyebrow">Senior Software Engineer</div>
            <h1 class="hero-name">Mark<br><em>Scicluna</em></h1>
            <p class="hero-title">Cross-Platform · Spatial Computing · AI Systems</p>
            <p class="hero-desc">Building production-grade experiences across mobile, spatial, and web — from Flutter and SwiftUI to visionOS and Blazor. Based in Melbourne. 10+ years shipping real products.</p>
            <div class="hero-ctas">
                <a href="#work" class="btn-primary">View Work →</a>
                <a href="files/mark-scicluna-cv-may2026.pdf" download class="btn-ghost">Download CV ↓</a>
            </div>
            <div class="hero-social">
                <a href="https://github.com/carkus" target="_blank" rel="noopener noreferrer" class="social-link">GitHub ↗</a>
                <a href="https://www.linkedin.com/in/mark-scicluna-b907809/" target="_blank" rel="noopener noreferrer" class="social-link">LinkedIn ↗</a>
                <a href="mailto:dicarkus@hotmail.com" class="social-link">Email ↗</a>
            </div>
        </div>
        <div class="hero-visual">
            <div class="platform-card">
                <img class="platform-img" src="@_current.ImageUrl" alt="@_current.ImageAlt"
                     style="opacity: @(_visible ? "0.55" : "0")" />
                <div class="platform-overlay"></div>
                @if (_current.Links.Length > 0)
                {
                    <div class="platform-links" style="opacity: @(_visible ? "1" : "0")">
                        @foreach (var link in _current.Links)
                        {
                            <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="platform-link">@link.Label</a>
                        }
                    </div>
                }
                <div class="platform-label" style="opacity: @(_visible ? "1" : "0")">
                    <span>Featured Platform</span>
                    <p>@_current.Title</p>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private WorkItem[] _items = Fallback;
    private int   _idx     = 0;
    private bool  _visible = true;
    private Timer? _timer;

    private WorkItem _current => _items[_idx];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var loaded = await Http.GetFromJsonAsync<WorkItem[]>("data/workitems.json", opts);
            var featured = loaded?.Where(i => i.Featured).ToArray();
            if (featured is { Length: > 0 })
                _items = featured;
        }
        catch { }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && _items.Length > 1)
            _timer = new Timer(_ => InvokeAsync(Advance), null, 8000, 8000);
    }

    private async Task Advance()
    {
        _visible = false;
        StateHasChanged();
        await Task.Delay(700);
        _idx = (_idx + 1) % _items.Length;
        _visible = true;
        StateHasChanged();
    }

    public void Dispose() => _timer?.Dispose();

    private static readonly WorkItem[] Fallback =
    [
        new("ZOME — Cross-platform product suite",
            ["Flutter", "Swift", "Kotlin", "visionOS"],
            "https://images.unsplash.com/photo-1759661990336-51bd4b951fea?w=600&q=80",
            "ZOME platform",
            "",
            Featured: true,
            [
                new("App Store ↗", "https://itunes.apple.com/us/app/zome/id1382123356?ls=1&mt=8"),
                new("Play Store ↗", "https://play.google.com/store/apps/details?id=com.zomecorp.zome"),
            ]),
        new("Chatty Prayers",
            ["Blazor", "C#", "AI"],
            "https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=600&q=80",
            "Chatty Prayers",
            "", Featured: false, []),
    ];
}
