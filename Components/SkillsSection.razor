@inject IJSRuntime JS
@inject HttpClient Http
@using System.Text.Json

<section id="skills">
    <div class="section-inner">
        <div class="section-eyebrow reveal">Skills</div>
        <h2 class="section-heading reveal reveal-delay-1">The toolkit</h2>
        <p class="section-sub reveal reveal-delay-2">Sorted by depth — high proficiency covers my daily drivers, extended stack what I reach for regularly, and other skills round out the rest.</p>
    </div>
    <div class="section-inner" style="padding-top:0;">
        <div class="skills-board" id="skillsBoard">
            @foreach (var col in _cols)
            {
                <div class="skills-col">
                    <div class="skills-col-header">@col.Header</div>
                    @foreach (var s in col.Skills)
                    {
                        <div class="skill-row" style="--pct:@(s.Pct)%">
                            <div class="skill-row-identity">
                                <div class="skill-row-icon">
                                    @if (s.Icon.StartsWith("devicon-"))
                                    {
                                        <i class="@s.Icon"></i>
                                    }
                                    else
                                    {
                                        <span>@s.Icon</span>
                                    }
                                </div>
                                <div>
                                    <div class="skill-row-name">@s.Name</div>
                                    <div class="skill-row-cat">@s.Cat</div>
                                </div>
                            </div>
                            <div class="skill-row-meter">
                                <div class="skill-row-prof-label">
                                    Proficiency <span class="skill-row-pct">@(s.Pct)%</span>
                                </div>
                                <div class="skill-row-bar">
                                    <div class="skill-row-bar-fill"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        @if (_otherSkills.Length > 0)
        {
            <div class="skills-other-box">
                <div class="skills-col-header">Other Skills</div>
                <div class="skills-other">
                    @foreach (var s in _otherSkills)
                    {
                        <span class="skill-box etag">@s.Name</span>
                    }
                </div>
            </div>
        }
    </div>
</section>

@code {
    private Col[] _cols = BuildCols(FlatFallback);
    private Skill[] _otherSkills = OtherSkills(FlatFallback);
    private bool _justLoaded;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var loaded = await Http.GetFromJsonAsync<Skill[]>("data/skills.json", opts);
            if (loaded is { Length: > 0 })
            {
                _cols = BuildCols(loaded);
                _otherSkills = OtherSkills(loaded);
                _justLoaded = true;
            }
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _justLoaded)
        {
            _justLoaded = false;
            await JS.InvokeVoidAsync("initSkillsBoard", "skillsBoard");
        }
    }

    private record Skill(string Name, string Cat, string Icon, int Pct);
    private record Col(string Header, Skill[] Skills);

    private static Col[] BuildCols(Skill[] skills)
    {
        var sorted = skills.OrderByDescending(s => s.Pct).ToArray();
        var cols = new List<Col>();
        if (sorted.Length > 0) cols.Add(new("High Proficiency", sorted.Take(6).ToArray()));
        if (sorted.Length > 6) cols.Add(new("Extended Stack",   sorted.Skip(6).Take(6).ToArray()));
        return cols.ToArray();
    }

    private static Skill[] OtherSkills(Skill[] skills) =>
        skills.OrderByDescending(s => s.Pct).Skip(12).ToArray();

    private static readonly Skill[] FlatFallback =
    [
        new("Flutter/Dart",        "Mobile",       "devicon-flutter-plain colored",    95),
        new("Swift / SwiftUI",     "iOS",          "devicon-swift-plain colored",      92),
        new("visionOS",            "Spatial",      "devicon-apple-plain",              90),
        new("Blazor",              "Web",          "devicon-blazor-plain colored",     90),
        new("UIKit",               "iOS",          "devicon-xcode-plain colored",      88),
        new("Claude API",          "AI",           "◆",                                88),
        new("React",               "Web",          "devicon-react-original colored",   86),
        new("C#",                  "Language",     "devicon-csharp-plain colored",     86),
        new("RealityKit",          "Spatial",      "devicon-apple-plain",              82),
        new("Kotlin",              "Android",      "devicon-kotlin-plain colored",     80),
        new("Heuristic Search",    "AI Research",  "◆",                                80),
        new("DDD",                 "Architecture", "◆",                                78),
        new("AI Planning",         "Research",     "◆",                                78),
        new("ARKit",               "Spatial",      "devicon-apple-plain",              76),
        new("Git / CI·CD",         "Tooling",      "devicon-git-plain colored",        75),
        new("PDF Generation",      "Web",          "◆",                                75),
        new("Python",              "Scripting",    "devicon-python-plain colored",     74),
        new("Observable",          "Patterns",     "◆",                                72),
        new("TypeScript",          "Language",     "devicon-typescript-plain colored", 72),
        new("ASP.NET Core",        "Backend",      "devicon-dotnetcore-plain colored", 70),
        new("Jetpack Compose",     "Android",      "devicon-android-plain colored",    70),
        new("Gemini API",          "AI",           "devicon-google-plain colored",     65),
        new("Distributed Systems", "Systems",      "◆",                                65),
        new("systemd",             "DevOps",       "devicon-linux-plain colored",      60),
        new("ActionScript",        "Legacy",       "devicon-flash-plain colored",      50),
    ];
}
