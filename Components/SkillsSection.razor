@inject IJSRuntime JS
@inject HttpClient Http
@using System.Text.Json

<section id="skills">
    <div class="section-inner">
        <div class="section-eyebrow reveal">Skills</div>
        <h2 class="section-heading reveal reveal-delay-1">The toolkit</h2>
        <p class="section-sub reveal reveal-delay-2">Languages, frameworks, and platforms I work with day-to-day — and a few I reach for when the problem calls for it.</p>
    </div>
    <div class="section-inner" style="padding-top:0;">
        <div class="skills-board" id="skillsBoard">
            @foreach (var col in _cols)
            {
                <div class="skills-col">
                    <div class="skills-col-header">@col.Header</div>
                    @foreach (var s in col.Skills)
                    {
                        <div class="skill-row" style="--pct:@(s.Pct)%">
                            <div class="skill-row-identity">
                                <div class="skill-row-icon">@s.Icon</div>
                                <div>
                                    <div class="skill-row-name">@s.Name</div>
                                    <div class="skill-row-cat">@s.Cat</div>
                                </div>
                            </div>
                            <div class="skill-row-meter">
                                <div class="skill-row-prof-label">
                                    Proficiency <span class="skill-row-pct">@(s.Pct)%</span>
                                </div>
                                <div class="skill-row-bar">
                                    <div class="skill-row-bar-fill"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        @if (_otherSkills.Length > 0)
        {
            <div class="skills-other">
                @foreach (var s in _otherSkills)
                {
                    <span class="skill-box etag">@s.Icon @s.Name</span>
                }
            </div>
        }
    </div>
</section>

@code {
    private Col[] _cols = BuildCols(FlatFallback);
    private Skill[] _otherSkills = OtherSkills(FlatFallback);
    private bool _justLoaded;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var loaded = await Http.GetFromJsonAsync<Skill[]>("data/skills.json", opts);
            if (loaded is { Length: > 0 })
            {
                _cols = BuildCols(loaded);
                _otherSkills = OtherSkills(loaded);
                _justLoaded = true;
            }
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _justLoaded)
        {
            _justLoaded = false;
            await JS.InvokeVoidAsync("initSkillsBoard", "skillsBoard");
        }
    }

    private record Skill(string Name, string Cat, string Icon, int Pct);
    private record Col(string Header, Skill[] Skills);

    private static Col[] BuildCols(Skill[] skills)
    {
        var sorted = skills.OrderByDescending(s => s.Pct).ToArray();
        var cols = new List<Col>();
        if (sorted.Length > 0) cols.Add(new("High Proficiency", sorted.Take(6).ToArray()));
        if (sorted.Length > 6) cols.Add(new("Extended Stack",   sorted.Skip(6).Take(6).ToArray()));
        return cols.ToArray();
    }

    private static Skill[] OtherSkills(Skill[] skills) =>
        skills.OrderByDescending(s => s.Pct).Skip(12).ToArray();

    private static readonly Skill[] FlatFallback =
    [
        new("Flutter",             "Mobile",       "🐦",  95),
        new("C#",                  "Language",     "🔷",  95),
        new("Dart",                "Language",     "🎯",  94),
        new("Swift / SwiftUI",     "iOS",          "🍎",  92),
        new("visionOS",            "Spatial",      "🥽",  90),
        new("Blazor",              "Web",          "🌐",  90),
        new("UIKit",               "iOS",          "📐",  88),
        new("Claude API",          "AI",           "🧠",  88),
        new("Git / CI·CD",         "Tooling",      "🔀",  85),
        new("RealityKit",          "Spatial",      "🔮",  82),
        new("Kotlin",              "Android",      "🔶",  80),
        new("Heuristic Search",    "AI Research",  "🔬",  80),
        new("DDD",                 "Architecture", "🏛️",  78),
        new("AI Planning",         "Research",     "🤖",  78),
        new("ARKit",               "Spatial",      "🕶️",  76),
        new("PDF Generation",      "Web",          "📄",  75),
        new("React",               "Web",          "⚛️",  75),
        new("Python",              "Scripting",    "🐍",  74),
        new("Observable",          "Patterns",     "👁️",  72),
        new("TypeScript",          "Language",     "📘",  72),
        new("ASP.NET Core",        "Backend",      "⚙️",  70),
